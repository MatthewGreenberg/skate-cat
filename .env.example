# Required only for the global leaderboard (Vercel serverless functions in /api).
# The game itself runs fully offline with `npm run dev` — no env needed.
#
# To wire up the leaderboard:
#   1. Create a Supabase project with a `leaderboard` table
#      (columns: initials text, score int, rank text, created_at timestamptz)
#   2. Copy this file to `.env` and fill in the values below
#   3. Run `vercel dev` (not `npm run dev`) to serve /api routes locally
#   4. Set the same vars in your Vercel project dashboard for production

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
